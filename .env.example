# RPG Recorder — environment variables
# Copy to .env and fill in values

# Required: Discord bot token (from https://discord.com/developers/applications)
DISCORD_TOKEN=your-discord-bot-token-here

# Optional: Guild (server) ID for instant slash-command sync during development.
# Leave unset for global sync (takes up to 1h to propagate).
# GUILD_ID=123456789012345678

# Directory where session folders are stored (default: ./sessions)
SESSIONS_DIR=sessions

# Logging level: DEBUG | INFO | WARNING | ERROR (default: INFO)
LOG_LEVEL=INFO
